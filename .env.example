# Copy to .env and fill in values

MONGODB_URI=mongodb://127.0.0.1:27017/agentatlas

JWT_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

FRONTEND_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/google/callback

# Transactional email via Resend (optional — password reset)
RESEND_API_KEY=
EMAIL_FROM=
# Or use the pair below instead of EMAIL_FROM
RESEND_FROM_EMAIL=
RESEND_FROM_NAME=agentatlas

# Per-user API tokens (optional prefix for automation PATs)
AGENT_KEY_PREFIX=aa_

PORT=3001

# Swarm inference (see docs/INFERENCE.md)
# auto = LLM when provider keys exist, else stub | llm = always LLM | stub = never call models
INFERENCE_MODE=auto
INFERENCE_DEFAULT_PROVIDER=openai_direct
INFERENCE_DEFAULT_MODEL=gpt-4o-mini
INFERENCE_DEFAULT_TEMPERATURE=0.35
# INFERENCE_DEFAULT_MAX_TOKENS=4096
INFERENCE_TIMEOUT_MS=120000

# OpenAI / OpenAI-compatible
OPENAI_API_KEY=
# INFERENCE_API_KEY=
# INFERENCE_BASE_URL=https://api.openai.com/v1

# Anthropic
# ANTHROPIC_API_KEY=
# ANTHROPIC_MAX_TOKENS_DEFAULT=4096

# OpenRouter
# OPENROUTER_API_KEY=
# OPENROUTER_INFERENCE_BASE_URL=https://openrouter.ai/api/v1

# Hugging Face router
# HF_TOKEN=
# HF_INFERENCE_BASE_URL=https://router.huggingface.co/v1

# Inference.net
# INFERENCE_NET_BASE_URL=
# INFERENCE_NET_API_KEY=

# Ollama (local OpenAI-compatible)
# OLLAMA_INFERENCE_BASE_URL=http://localhost:11434/v1
# OLLAMA_API_KEY=ollama

# xAI Grok (OpenAI-compatible Chat Completions)
# XAI_API_KEY=
# GROK_INFERENCE_BASE_URL=https://api.x.ai/v1

# Google Gemini (native Generative Language API)
# GEMINI_API_KEY=
# GOOGLE_API_KEY=
# GEMINI_INFERENCE_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Cloudflare Browser Run (tools — webpage scrape)
# API token needs "Browser Rendering - Edit" on the SAME account as ACCOUNT_ID below.
# Account ID: Cloudflare dashboard → Workers & Pages → Overview (right column), NOT a zone ID.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_BROWSER_RUN_TIMEOUT_MS=60000
# Optional cap on markdown chars returned to agents (raw scrape is still stored in DB)
# SCRAPE_CONTENT_MAX_CHARS=120000
